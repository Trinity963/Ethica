        self._toolbar.pack(fill=tk.X, side=tk.TOP)
        self._toolbar.pack_propagate(False)

        # Title
        tk.Label(
            self._toolbar,
            text="Living Page",
            bg=c["bg_secondary"],
            fg=c["accent_bright"],
            font=f("title")
        ).pack(side=tk.LEFT, padx=(0, 16))

        # Mode selector
        tk.Label(
            self._toolbar,
            text="Mode:",
            bg=c["bg_secondary"],
            fg=c["text_muted"],
            font=f("small")
        ).pack(side=tk.LEFT, padx=(0, 4))

        self._mode_var = tk.StringVar(value="document")
        mode_menu = ttk.Combobox(
            self._toolbar,
            textvariable=self._mode_var,
            values=[m["label"] for m in MODES.values()],
            width=10,
            state="readonly"
        )
        mode_menu.pack(side=tk.LEFT, padx=(0, 12))
        mode_menu.bind("<<ComboboxSelected>>", self._on_mode_change)

        # Always on top toggle
        self._ontop_var = tk.BooleanVar(value=False)
        tk.Checkbutton(
            self._toolbar,
            text="Pin",
            variable=self._ontop_var,
            bg=c["bg_secondary"],
            fg=c["text_muted"],
            selectcolor=c["bg_secondary"],
            activebackground=c["bg_secondary"],
            activeforeground=c["accent_bright"],
            font=f("small"),
            command=self._toggle_ontop
        ).pack(side=tk.LEFT, padx=(0, 12))

        # New tab button
        tk.Button(
            self._toolbar,
            text="+ Tab",
            bg=c["button_bg"],
            fg=c["button_text"],
            font=f("small"),
            relief=tk.FLAT,
            padx=10,
            pady=2,
            cursor="hand2",
            command=self._add_tab
        ).pack(side=tk.RIGHT)

        # New project tab button
        tk.Button(
            self._toolbar,
            text="✦ Project",
            bg=c["accent_soft"],
            fg=c["accent_bright"],
            font=f("small"),
            relief=tk.FLAT,
            padx=10,
            pady=2,
            cursor="hand2",
            command=self._add_project_tab
        ).pack(side=tk.RIGHT, padx=(0, 4))

        # New sketch tab button
        tk.Button(
            self._toolbar,
            text="✏ Sketch",
            bg=c["accent_soft"],
            fg=c["accent_bright"],
            font=f("small"),
            relief=tk.FLAT,
            padx=10,
            pady=2,
            cursor="hand2",
            command=self._add_sketch_tab
        ).pack(side=tk.RIGHT, padx=(0, 4))

        # Settings button
        tk.Button(
            self._toolbar,
            text="⚙ Settings",
            bg=c["bg_secondary"],
            fg=c["text_muted"],
            font=f("small"),
            relief=tk.FLAT,
            padx=10,
            pady=2,
            cursor="hand2",
            command=self._open_settings
        ).pack(side=tk.RIGHT, padx=(0, 4))

        # New debug tab button
        tk.Button(
            self._toolbar,
            text="⚙ Debug",
            bg=c["accent_soft"],
            fg=c["accent_bright"],
            font=f("small"),
            relief=tk.FLAT,
            padx=10,
            pady=2,
            cursor="hand2",
            command=self._add_debug_tab
        ).pack(side=tk.RIGHT, padx=(0, 4))

        # Run active tab in debug executor
        tk.Button(
            self._toolbar,
            text="▶ Run",
            bg=c["accent_soft"],
            fg=c["accent_bright"],
            font=f("small"),
            relief=tk.FLAT,
            padx=10,
            pady=2,
            cursor="hand2",
            command=self._run_active_tab
        ).pack(side=tk.RIGHT, padx=(0, 4))

        # Clear button
        tk.Button(
            self._toolbar,
