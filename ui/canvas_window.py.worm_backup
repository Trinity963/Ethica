    "sketch":   {"label": "Sketch",   "font_style": "body",   "wrap": tk.WORD},
    "debug":    {"label": "Debug",    "font_style": "mono",   "wrap": tk.NONE},
    "modules":  {"label": "Modules",  "font_style": "body",   "wrap": tk.WORD},
}

# ── Canvas State File ─────────────────────────────────────────

BASE_DIR = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
CANVAS_STATE_FILE = os.path.join(BASE_DIR, "memory", "canvas_state.json")


class CanvasTab:
    """
    A single tab on the living canvas.
    Has its own mode, content, and name.
    """

    def __init__(self, name="Untitled", mode="document", content=""):
        self.name = name
        self.mode = mode
        self.content = content
        self.images = []  # PhotoImage refs for PDF tabs — prevents GC
        self.created = datetime.now().isoformat()
        self.modified = self.created

    def to_dict(self):
        return {
            "name": self.name,
            "mode": self.mode,
            "content": self.content,
            "created": self.created,
            "modified": self.modified
        }

    @classmethod
    def from_dict(cls, d):
        tab = cls(
            name=d.get("name", "Untitled"),
            mode=d.get("mode", "document"),
            content=d.get("content", "")
        )
        tab.created = d.get("created", tab.created)
        tab.modified = d.get("modified", tab.modified)
        return tab


class CanvasWindow:
    """
    Ethica's Living Canvas.

    A floating, detachable workspace that exists alongside
    the chat window but never bleeds into it.

    Shared context — whatever lives here, Ethica knows about.
    Both V and Ethica can read and write to this surface.

    Features:
    - Floating window, resizable, position remembered
    - Multiple named tabs
    - Three modes: Code, Document, Output
    - Ethica can push content directly
    - Content is injected into Ethica's context silently
    - Persists across sessions
    """

    WINDOW_TITLE = "✦ Canvas  —  Living Page"
    MIN_WIDTH    = 600
    MIN_HEIGHT   = 400
    DEFAULT_W    = 800
    DEFAULT_H    = 600

    def __init__(self, parent, theme, config, on_content_change=None, connector=None, modules=None, notify_fn=None):
        self.parent = parent
        self.theme = theme
        self.config = config
        self.on_content_change = on_content_change
        self.notify_fn = notify_fn
        self.connector = connector  # For DebugView Ethica commentary

        self._window = None
        self._tabs = []
        self._active_tab_index = 0
        self._tab_widgets = {}
        self._text_widgets = {}
        self._is_open = False
        self._editor = None
        self._line_numbers = None
        self._history_panel = None
        self._history_panel_open = False
        self._project_view = None   # Active ProjectView instance if in project mode
        self._sketch_view  = None   # Active SketchView instance if in sketch mode
        self._debug_view        = None   # Active DebugView instance if in debug mode
        self._module_store_view = None   # Active ModuleStoreView instance
        self._settings_view = None       # Active SettingsView instance
        self._modules           = modules  # Module registry reference

        # Version control engine
        self.history = CanvasHistory()

        # Load saved state
        self._load_state()

        # Ensure at least one tab
        if not self._tabs:
            self._tabs.append(CanvasTab(name="Page 1", mode="document"))

    # ── Window Lifecycle ──────────────────────────────────────

    def open(self):
        """Open the canvas window. Creates if not exists."""
        if self._window and self._window.winfo_exists():
            self._window.lift()
            self._window.focus_force()
            return

        self._build_window()
        self._is_open = True

    def close(self):
        """Close the canvas window."""
        if self._window:
            self._save_state()
            self._window.destroy()
            self._window = None
        self._is_open = False
        # Clear requirements cache on canvas close
        try:
            from pathlib import Path
            cache_path = Path.home() / 'Ethica/status/req_cache.json'
            if cache_path.exists():
                cache_path.unlink()
        except Exception:
            pass

    def toggle(self):
        """Toggle canvas open/closed."""
        if self._is_open and self._window and self._window.winfo_exists():
            self.close()
        else:
            self.open()

    def is_open(self):
        return self._is_open and self._window and self._window.winfo_exists()

    # ── Window Build ──────────────────────────────────────────

    def _build_window(self):
        """Build the floating canvas window."""
        c = self.theme.colors
        f = self.theme.font

        # Restore saved geometry or use defaults
        geo = self.config.get(
            "canvas_geometry",
            f"{self.DEFAULT_W}x{self.DEFAULT_H}+100+100"
        )

        self._window = tk.Toplevel(self.parent)
        self._window.title(self.WINDOW_TITLE)
        self._window.geometry(geo)
        self._window.minsize(self.MIN_WIDTH, self.MIN_HEIGHT)
        self._window.configure(bg=c["bg_primary"])

        # Save geometry on close
        self._window.protocol("WM_DELETE_WINDOW", self._on_close)
        self._window.bind("<Configure>", self._on_configure)

        # Build layout
        self._build_toolbar()
        self._build_tab_bar()
        self._build_editor_area()
        self._build_canvas_drop()
        self._build_statusbar()

        # Load tabs into UI
        self._render_tabs()
        self._switch_tab(self._active_tab_index)

    # ── Canvas File Drop Zone ─────────────────────────────────
    def _build_canvas_drop(self):
        """Drop zone bar above status bar — routes files to correct tab type."""
        self._canvas_drop = ScrollDrop(
            parent=self._window,
            theme=self.theme,
            config=self.config,
            on_file_drop=self._on_canvas_file_drop
        )
        self._canvas_drop.frame.pack(fill=tk.X, side=tk.BOTTOM)

    def open_file(self, filepath):
        """Public entry point — open a file in the canvas (e.g. from Memory Search)."""
        self.open()
        self._on_canvas_file_drop(filepath)

    def _on_canvas_file_drop(self, filepath):
        """Route dropped file to correct Canvas tab by extension."""
        import os
        ext = os.path.splitext(filepath)[1].lower()
        filename = os.path.basename(filepath)

        try:
            with open(filepath, 'r', encoding='utf-8', errors='replace') as f:
                content = f.read()
        except Exception as e:
            print(f'[CanvasDrop] read error: {e}')
            return

        # Extension → debug tab language mapping
        DEBUG_MAP = {
            '.py':   'Python',
            '.js':   'JavaScript',
            '.jsx':  'JavaScript',
            '.ts':   'JavaScript',
            '.tsx':  'JavaScript',
            '.rs':   'Rust',
            '.sh':   'Bash',
            '.bash': 'Bash',
            '.html': 'HTML',
            '.htm':  'HTML',
            '.css':  'CSS',
            '.json': 'JSON',
            '.yaml': 'YAML',
            '.yml':  'YAML',
        }

        # Extension → document tab
        DOC_EXTS = {'.md', '.txt', '.rst', '.scroll', '.log'}

        IMAGE_EXTS = {'.png', '.jpg', '.jpeg'}

        if ext in IMAGE_EXTS:
            # Image — render in canvas image tab
            self._drop_as_image(filepath)
        elif ext in DEBUG_MAP:
            lang = DEBUG_MAP[ext]
            self.push_debug_from_ethica(content, tab_name=filename, lang=lang)
        elif ext in DOC_EXTS or ext in {'.yaml', '.yml'}:
            self._drop_as_document(content, filename)
        else:
            # Fallback — open as document
            self._drop_as_document(content, filename)

        # Auto-install missing imports for .py files
        if ext == '.py':
            import threading
            def _scan_and_install():
                import ast as _ast, subprocess, sys, json
                from pathlib import Path
                cache_path = Path.home() / 'Ethica/status/req_cache.json'
                try:
                    cache = json.loads(cache_path.read_text()) if cache_path.exists() else {}
                except Exception:
                    cache = {}
                try:
                    tree = _ast.parse(content)
                except SyntaxError:
                    return
                imports = set()
                for node in _ast.walk(tree):
                    if isinstance(node, _ast.Import):
                        for alias in node.names:
                            imports.add(alias.name.split('.')[0])
                    elif isinstance(node, _ast.ImportFrom) and node.module:
                        imports.add(node.module.split('.')[0])
                stdlib = set(sys.stdlib_module_names) if hasattr(sys, 'stdlib_module_names') else set()
                for mod in imports:
                    if mod in stdlib or mod in cache:
                        continue
                    try:
                        __import__(mod)
                        cache[mod] = 'ok'
                    except ImportError:
                        try:
                            subprocess.run(
                                ['/home/trinity/Ethica/Ethica_env/bin/pip', 'install', mod],
                                capture_output=True, timeout=60
                            )
                            cache[mod] = 'installed'
                        except Exception:
                            cache[mod] = 'failed'
                cache_path.parent.mkdir(parents=True, exist_ok=True)
                cache_path.write_text(json.dumps(cache, indent=2))
            threading.Thread(target=_scan_and_install, daemon=True).start()

        # Notification handled by _drop_as_document — do not fire here

    def _drop_as_document(self, file_content, filename):
        """Create a fresh Document tab for a dropped file and notify Tinity."""
        if not self._window or not self._window.winfo_exists():
            self.open()

        # Always create a new document tab named after the file
        new_tab = CanvasTab(name=filename, mode="document")
        new_tab.content = file_content
        self._tabs.append(new_tab)
        target_index = len(self._tabs) - 1
        self._switch_tab(target_index)

        # Load content into editor
        self._editor.delete("1.0", tk.END)
        self._editor.insert("1.0", file_content)
        self._save_active_tab_content()
        self.history.snapshot(filename, file_content, "document")
        self._update_status(f"Dropped: {filename}")

        # Notify Tinity via notify_fn — bypasses canvas_context, no River trigger
        preview = file_content.strip()[:300]
        if len(file_content.strip()) > 300:
            preview += "..."
        notification = (
            f"V dropped \"{filename}\" into the canvas.\n"
            f"Preview:\n{preview}"
        )
        if self.notify_fn:
            self.parent.after(200, lambda n=notification: self.notify_fn(n))
        _notify_canvas_drop(filename)
        self.parent.after(100, self._write_canvas_context)


    def _drop_as_pdf(self, filepath):
        """Extract text and render pages from a dropped PDF — two Document tabs."""
        import os
        import io
        filename = os.path.basename(filepath)

        if not self._window or not self._window.winfo_exists():
            self.open()

        # ── Text extraction ───────────────────────────────────
        try:
            import pypdf
            reader = pypdf.PdfReader(filepath)
            pages_text = []
            for i, page in enumerate(reader.pages):
                text = page.extract_text() or ""
                pages_text.append("-- Page " + str(i+1) + " --\n" + text)
            full_text = "\n\n".join(pages_text)
            if not full_text.strip():
                full_text = "[No extractable text found in this PDF]"
        except Exception as e:
            full_text = f"[PDF text extraction failed: {e}]"

        # Open text as Document tab
        text_tab_name = f"{filename} — Text"
        new_tab = CanvasTab(name=text_tab_name, mode="document")
        new_tab.content = full_text
        self._tabs.append(new_tab)
        self._switch_tab(len(self._tabs) - 1)
        self._editor.delete("1.0", tk.END)
        self._editor.insert("1.0", full_text)
        self._save_active_tab_content()
        self.history.snapshot(text_tab_name, full_text, "document")
        self._update_status(f"PDF text: {filename}")

        # -- Page images --
        pages_tab_name = filename + " -- Pages"
        pages_tab = CanvasTab(name=pages_tab_name, mode="pdf")
        pages_tab.content = ""
        try:
            from pdf2image import convert_from_path
            from PIL import ImageTk
            pil_images = convert_from_path(filepath, dpi=120)
            for pil_img in pil_images:
                tk_img = ImageTk.PhotoImage(pil_img)
                pages_tab.images.append(tk_img)
        except Exception as e:
            pages_tab.content = "[PDF page render failed: " + str(e) + "]"
            pages_tab.mode = "document"
        self._tabs.append(pages_tab)
        self._update_status(f"PDF loaded: {filename}")

        # Notify
        notification = (
            f"V dropped PDF \"{filename}\" into the canvas.\n"
            f"{len(full_text.splitlines())} text lines extracted."
        )
        if self.notify_fn:
            self.parent.after(200, lambda n=notification: self.notify_fn(n))
        _notify_canvas_drop(filename)
        self.parent.after(100, self._write_canvas_context)

    def _drop_as_image(self, filepath):
        """Render a dropped PNG/JPG as an image tab in the canvas."""
        import os
        from PIL import Image, ImageTk
        filename = os.path.basename(filepath)

        if not self._window or not self._window.winfo_exists():
            self.open()

        img_tab_name = f"{filename} — Image"
        img_tab = CanvasTab(name=img_tab_name, mode="pdf")
        img_tab.content = ""
        try:
            pil_img = Image.open(filepath)
            pil_img.thumbnail((900, 900))
            tk_img = ImageTk.PhotoImage(pil_img)
            img_tab.images.append(tk_img)
        except Exception as e:
            img_tab.content = f"[Image load failed: {e}]"
            img_tab.mode = "document"
        self._tabs.append(img_tab)
        self._switch_tab(len(self._tabs) - 1)
        self._update_status(f"Image loaded: {filename}")

        notification = f'V dropped image "{filename}" into the canvas.'
        if self.notify_fn:
            self.parent.after(200, lambda n=notification: self.notify_fn(n))
        _notify_canvas_drop(filename)
        self.parent.after(100, self._write_canvas_context)

