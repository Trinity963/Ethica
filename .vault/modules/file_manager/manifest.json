{
  "name": "FileManager",
  "version": "1.0",
  "entry": "file_manager.py",
  "description": "Sovereign file manager \u2014 list, read, copy, move, delete, tree, zip, unzip. Results in Ops.",
  "author": "Victory",
  "autonomous": false,
  "autonomous_triggers": [
    "list files",
    "show files",
    "file tree",
    "read file",
    "copy file",
    "move file",
    "delete file",
    "zip file",
    "unzip file",
    "extract zip",
    "archive folder",
    "zip status"
  ],
  "tools": [
    {
      "name": "fm_list",
      "description": "List files in a directory",
      "syntax": "[TOOL:fm_list: ~/path]",
      "autonomous": false,
      "example": "[TOOL:fm_list: ~/Ethica/modules]"
    },
    {
      "name": "fm_tree",
      "description": "Show directory tree",
      "syntax": "[TOOL:fm_tree: ~/path]",
      "autonomous": false,
      "example": "[TOOL:fm_tree: ~/Ethica]"
    },
    {
      "name": "fm_read",
      "description": "Read a text file",
      "syntax": "[TOOL:fm_read: ~/path/file.txt]",
      "autonomous": false,
      "example": "[TOOL:fm_read: ~/Ethica/README.md]"
    },
    {
      "name": "fm_copy",
      "description": "Copy a file to destination",
      "syntax": "[TOOL:fm_copy: ~/src.txt > ~/dest.txt]",
      "autonomous": false,
      "example": "[TOOL:fm_copy: ~/file.txt > ~/backup/file.txt]"
    },
    {
      "name": "fm_delete",
      "description": "Delete a file",
      "syntax": "[TOOL:fm_delete: ~/path/file.txt]",
      "autonomous": false,
      "example": "[TOOL:fm_delete: ~/tmp/old.txt]"
    },
    {
      "name": "fm_zip",
      "description": "Compress a file or folder into a .zip alongside the source",
      "syntax": "[TOOL:fm_zip: ~/path]",
      "autonomous": false,
      "example": "[TOOL:fm_zip: ~/Ethica/logs]"
    },
    {
      "name": "fm_unzip",
      "description": "Extract a .zip archive into its containing directory",
      "syntax": "[TOOL:fm_unzip: ~/path/file.zip]",
      "autonomous": false,
      "example": "[TOOL:fm_unzip: ~/Downloads/archive.zip]"
    },
    {
      "name": "fm_zip_status",
      "description": "List contents of a .zip without extracting",
      "syntax": "[TOOL:fm_zip_status: ~/path/file.zip]",
      "autonomous": false,
      "example": "[TOOL:fm_zip_status: ~/Downloads/archive.zip]"
    }
  ]
}